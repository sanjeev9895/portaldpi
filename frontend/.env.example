# ============================================================
# Vizhuthugal Dashboard — Frontend environment variables
# Copy to ".env" for local dev. In production set these in the
# Vercel project settings (Project -> Settings -> Environment Variables).
# ============================================================

# Supabase project URL: Supabase Dashboard -> Project Settings -> API -> Project URL
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Supabase anon/public key: Project Settings -> API -> Project API keys -> "anon" "public"
# This key is safe to expose in the browser; access is controlled by RLS.
VITE_SUPABASE_ANON_KEY=your-anon-public-key
